# Vorlage für die benötigten Umgebungsvariablen.
# Echte Werte NICHT hier eintragen — lokal in .env (gitignored), in Produktion
# im Vercel-Environment-Dashboard pflegen.

# ── Turso / libSQL Datenbanken ───────────────────────────────────────────────
# URL-Form: libsql://<db>-<org>.turso.io   ·   Token aus dem Turso-Dashboard.
PRODUKTE_DB_URL=
PRODUKTE_DB_AUTH_TOKEN=
BESUCHER_DB_URL=
BESUCHER_DB_AUTH_TOKEN=
EINSATZPLAN_DB_URL=
EINSATZPLAN_DB_AUTH_TOKEN=

# ── Admin-Auth ───────────────────────────────────────────────────────────────
# Shared-Secret für schreibende Admin-Endpunkte. Wird als Bearer-Token erwartet
# und ist zugleich das Login-Passwort im Admin-Panel. Stark wählen & rotieren.
ADMIN_API_TOKEN=

# ── Optional ─────────────────────────────────────────────────────────────────
# Zusätzliche erlaubte CORS-Origins (komma-separiert), z. B. eine zweite Domain.
CORS_EXTRA_ORIGINS=
# Verzeichnis für legacy lokale PDF-Vorlagen (nur lokales Backend).
LOCAL_PDF_DIR=
# Lokaler Serverport / Host (Default 3001 / 127.0.0.1).
PORT=
HOST=
