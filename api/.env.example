# ── DB-Verbindungen ──────────────────────────────────────────────────────────
# Ohne gesetzte Variablen läuft alles lokal im libSQL file:-Modus gegen api/db/*.sqlite.
# Für die Vercel/Turso-Demo je DB URL + Auth-Token setzen (Werte aus `turso db show` /
# `turso db tokens create`). Nur diese Variablen wechseln — der Code bleibt identisch.

# Produkt-/Preisdaten
# PRODUKTE_DB_URL=libsql://produkte-<org>.turso.io
# PRODUKTE_DB_AUTH_TOKEN=

# Besucherdaten
# BESUCHER_DB_URL=libsql://besucher-<org>.turso.io
# BESUCHER_DB_AUTH_TOKEN=

# Einsatzplan
# EINSATZPLAN_DB_URL=libsql://einsatzplan-<org>.turso.io
# EINSATZPLAN_DB_AUTH_TOKEN=
